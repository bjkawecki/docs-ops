# Production (intranet): HTTP on port 80. /api → backend, / → static frontend (nginx).
{
	auto_https disable_redirects
	log {
		output stdout
		format console
	}
}

http://:80 {
	handle /health {
		reverse_proxy app:8080
	}
	handle /ready {
		reverse_proxy app:8080
	}
	handle /api/* {
		reverse_proxy app:8080
	}
	handle {
		reverse_proxy frontend:80
	}
}
