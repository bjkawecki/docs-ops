# Basis-Image für App- und Frontend-Dev-Container: pnpm ist bereits aktiviert.
# Debian/glibc (nicht Alpine): geteiltes node_modules mit dem Linux-Host (Rollup/Vite native bindings).
# Beim Start laufen die Services mit user ${UID}:${GID}, sodass node_modules dir gehören.
FROM node:24-bookworm-slim
ARG TYPST_VERSION=0.13.1
COPY docker/install-typst-debian.sh /tmp/install-typst-debian.sh
RUN apt-get update \
  && apt-get install -y --no-install-recommends wget postgresql-client zstd tar xz ca-certificates \
  && TYPST_VERSION="${TYPST_VERSION}" sh /tmp/install-typst-debian.sh \
  && rm /tmp/install-typst-debian.sh \
  && rm -rf /var/lib/apt/lists/* \
  && corepack enable pnpm

ENV PNPM_HOME="/pnpm"
ENV PATH="$PNPM_HOME:$PATH"

RUN mkdir -p /pnpm && chmod 777 /pnpm
