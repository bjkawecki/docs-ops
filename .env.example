# Kopie als .env anlegen; Werte anpassen. Nicht committen!
#
# Nur Entwicklung / prod-nah lokal (Repo-Root). Production (Intranet): keine .env im Clone –
# Install-Skript legt /etc/docsops/docsops.env an. Siehe docs/install.md.
#
# Für Schnell-Dev (Postgres in Docker): Host = localhost
# Für App im Docker (compose): Host = postgres

# Docker Compose (app/frontend/deps): Rechte für node_modules. Bei EACCES setzen: UID=$(id -u) GID=$(id -g)
# UID=1000
# GID=1001
#
# Compose-Projektname und Container-Prefix (Standard: docsops → docsops-postgres, docsops-app, …).
# COMPOSE_PROJECT_NAME=docsops

DATABASE_URL=postgresql://app:app@localhost:5432/docsops

# Dev-only debug menu: reset / re-seed only when DATABASE_URL database name is listed here (comma-separated).
# DEV_DESTRUCTIVE_DB_NAMES=docsops

# Logging (optional)
# LOG_LEVEL=info
# LOG_HTTP_REQUESTS=false   # no per-request access logs (default in docker-compose.override)
# LOG_HTTP_REQUESTS=true    # log every request including /ready (debug)

# MinIO (S3-kompatibel, Anhänge/PDF-Export). Endpoint/Host für Backend-S3-Client.
# MINIO_ENDPOINT=http://localhost:9000
# MINIO_ACCESS_KEY=docsops
# MINIO_SECRET_KEY=docsopsdev
# MINIO_BUCKET=documents
# Im Dev-Setup: MinIO-Container nutzt MINIO_ROOT_USER/MINIO_ROOT_PASSWORD; dieselben Werte als MINIO_ACCESS_KEY/MINIO_SECRET_KEY verwenden.

# Admin anlegen: make admin-create (liest ADMIN_EMAIL, ADMIN_PASSWORD; legt nur an, wenn noch kein Admin)
# ADMIN_EMAIL=admin@example.com
# ADMIN_PASSWORD=
# Optional: ADMIN_NAME=Admin
# Im vollen Stack (docker compose) liest die App-Container-Startsequenz dieselben Variablen und legt ggf. einen Admin an.

# Login im Browser: Im Stack immer http://localhost:5000 nutzen (eine Origin; /api geht ans Backend).
# Nur Frontend lokal (pnpm --filter frontend dev): Backend getrennt starten (z. B. make dev, Port 8080) – Vite leitet /api dorthin.
# Anderes Backend-Ziel für den Vite-Proxy: VITE_DEV_PROXY_API=http://127.0.0.1:8080
# Komplett andere API-Origin (selten): VITE_API_URL=https://…

# Auth (Sessions)
SESSION_SECRET=
# HTTP intranet (default prod on port 80): leave unset or 0. With HTTPS/TLS: SESSION_COOKIE_SECURE=1
# SESSION_COOKIE_SECURE=1
# Optional: Session-Laufzeit in Sekunden (Default z. B. 7 Tage = 604800)
# SESSION_MAX_AGE_SECONDS=604800

# Legacy: persönlicher Markdown-Entwurf + Draft-Request-PRs (EPIC-9). In Production standardmäßig aus.
# DOCUMENT_LEGACY_DRAFT_ENABLED=false

# Demo instance only (docker-compose.demo.yml): load CSV seed when DB has no company.
# Intranet production: leave unset. Dev (NODE_ENV=development) seeds automatically.
# DEMO_MODE=true

# In-App-Benachrichtigungen (optional; siehe docs/plan/Env-und-Config.md)
# NOTIFICATION_RETENTION_DAYS=90
# NOTIFICATION_COALESCE_WINDOW_MINUTES=15
# NOTIFICATION_HARD_CAP_PER_USER=0
# Worker: periodisch Job maintenance.cleanup mit task user-notifications-retention einplanen

# Operational backup (§25): encrypt destination credentials at rest (32 bytes, base64)
# Generate: openssl rand -base64 32
# Use quotes when the value contains + or / ; restart app and docsops-job-worker after changes.
# BACKUP_ENCRYPTION_KEY="<paste-generated-key-here>"
# Optional install default when BackupSettings row not yet customized:
# BACKUP_RETENTION_COUNT=7
# Max upload size for Admin → Backup restore upload (bytes). Default: 5368709120 (5 GiB).
# BACKUP_RESTORE_UPLOAD_MAX_BYTES=5368709120
#
# Optional: bootstrap default external S3 destination on startup when none exists yet.
# Dev (MinIO offsite bucket in same stack): set BOOTSTRAP + INSECURE + bucket; endpoint/credentials fall back to MINIO_*.
# Prod: use real https:// S3 endpoint; do not set BACKUP_ALLOW_INSECURE_S3_DESTINATIONS.
# BACKUP_BOOTSTRAP_S3_DESTINATION=true
# BACKUP_ALLOW_INSECURE_S3_DESTINATIONS=true
# BACKUP_S3_DESTINATION_NAME=Dev offsite (MinIO)
# BACKUP_S3_DESTINATION_BUCKET=docsops-backups
# BACKUP_S3_DESTINATION_ENDPOINT=https://s3.eu-central-1.amazonaws.com
# BACKUP_S3_DESTINATION_ACCESS_KEY=
# BACKUP_S3_DESTINATION_SECRET_KEY=
# BACKUP_S3_DESTINATION_BASE_PATH=docsops
# BACKUP_S3_DESTINATION_REGION=eu-central-1
#
# PDF export (job worker): typst compile (default in Docker worker image)
# TYPST_BIN=typst
# TYPST_ARGS=
#
# Admin update check (§26): GitHub Releases repo; default bjkawecki/docs-ops when unset.
# Disable in Admin → System via "Automatic update checks" switch.
# DOCSOPS_UPDATE_GITHUB_REPO=bjkawecki/docs-ops
# DOCSOPS_UPDATE_CHECK_CACHE_TTL_SECONDS=86400
#
# WebDAV (optional): BACKUP_ALLOW_INSECURE_WEBDAV_DESTINATIONS=true allows http:// in dev (MinIO-style; not for production).
# Optional global Host header override: DOCSOPS_WEBDAV_DEFAULT_HOST_HEADER=cloud.example.com
# Per-destination hostHeader in Admin → Backup is preferred when using a reverse proxy.
