{
  "name": "engineering-knowledge-operations",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=24"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/engines",
      "argon2",
      "esbuild",
      "prisma"
    ],
    "overrides": {
      "@types/react": "^19.0.0",
      "@types/react-dom": "^19.0.0"
    }
  },
  "scripts": {
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{js,ts,tsx,json,md,yml,yaml}": "prettier --write",
    "*.{js,ts,tsx}": "eslint --fix"
  },
  "devDependencies": {
    "@eslint/js": "^9.15.0",
    "eslint": "^9.15.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "husky": "^9.1.7",
    "jscpd": "^4.0.9",
    "knip": "^6.6.1",
    "lint-staged": "^15.4.3",
    "prettier": "^3.3.3",
    "prisma": "^7.7.0",
    "ts-prune": "^0.10.3",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.15.0"
  },
  "optionalDependencies": {
    "@rollup/rollup-linux-x64-gnu": "4.59.0"
  },
  "dependencies": {
    "@prisma/client": "^7.7.0"
  }
}
