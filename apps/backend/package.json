{
  "name": "backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    "./api-types": "./src/api-types.ts"
  },
  "scripts": {
    "dev": "tsx scripts/run-with-app-version.ts -- tsx watch src/entrypoints/api.ts",
    "worker:dev": "tsx scripts/run-with-app-version.ts -- tsx watch src/entrypoints/worker.ts",
    "build": "pnpm exec prisma generate && tsc -p tsconfig.build.json",
    "start": "tsx scripts/run-with-app-version.ts -- node dist/src/entrypoints/api.js",
    "worker:start": "tsx scripts/run-with-app-version.ts -- node dist/src/entrypoints/worker.js",
    "prepare": "pnpm exec prisma generate",
    "prisma:generate": "pnpm exec prisma generate",
    "test": "vitest run",
    "create-admin": "tsx scripts/create-admin.ts",
    "seed": "tsx scripts/run-seed.ts",
    "backfill-context-owner-display": "tsx scripts/run-backfill-context-owner-display.ts",
    "backfill-document-blocks": "tsx scripts/run-backfill-document-blocks.ts",
    "wait-for-database": "tsx scripts/wait-for-database.ts",
    "migrate:remove-failed-user-preferences": "pnpm exec prisma db execute --file scripts/remove-failed-user-preferences-migration.sql",
    "loadtest:jobs": "tsx scripts/run-jobs-loadtest.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.700.0",
    "@aws-sdk/s3-request-presigner": "^3.700.0",
    "@fastify/cookie": "^11.0.2",
    "@fastify/multipart": "^10.0.0",
    "@prisma/adapter-pg": "^7.7.0",
    "@prisma/client": "^7.7.0",
    "argon2": "^0.44.0",
    "dotenv": "^16.4.5",
    "fastify": "^5.1.0",
    "pg": "^8.13.0",
    "pg-boss": "^12.15.0",
    "ssh2": "^1.17.0",
    "ssh2-sftp-client": "^12.1.1",
    "three-way-merge": "^0.1.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^24.13.2",
    "@types/pg": "^8.16.0",
    "@types/ssh2-sftp-client": "^9.0.6",
    "@types/supertest": "^7.2.0",
    "pino-pretty": "^13.1.3",
    "prisma": "^7.7.0",
    "supertest": "^7.2.2",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^4.0.18"
  }
}
