{
  "name": "backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    "./api-types": "./src/api-types.ts"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "worker:dev": "tsx watch src/worker.ts",
    "build": "pnpm exec prisma generate && tsc",
    "start": "node dist/src/index.js",
    "worker:start": "node dist/src/worker.js",
    "prepare": "pnpm exec prisma generate",
    "prisma:generate": "pnpm exec prisma generate",
    "test": "vitest run",
    "create-admin": "tsx scripts/create-admin.ts",
    "seed": "tsx scripts/run-seed.ts",
    "backfill-context-owner-display": "tsx scripts/run-backfill-context-owner-display.ts",
    "migrate:remove-failed-user-preferences": "pnpm exec prisma db execute --file scripts/remove-failed-user-preferences-migration.sql"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.700.0",
    "@aws-sdk/s3-request-presigner": "^3.700.0",
    "@fastify/cookie": "^11.0.2",
    "@prisma/adapter-pg": "^7.4.0",
    "@prisma/client": "^7.4.0",
    "argon2": "^0.44.0",
    "fastify": "^5.1.0",
    "pg": "^8.13.0",
    "pg-boss": "^12.15.0",
    "prisma": "^7.4.0",
    "three-way-merge": "^0.1.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@rollup/rollup-linux-x64-gnu": "4.59.0",
    "@types/node": "^22.10.0",
    "@types/pg": "^8.16.0",
    "@types/supertest": "^7.2.0",
    "dotenv": "^16.4.5",
    "pino-pretty": "^13.1.3",
    "prisma": "^7.4.0",
    "supertest": "^7.2.2",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^4.0.18"
  }
}
